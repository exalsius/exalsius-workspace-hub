{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Marimo Helm Chart Values",
  "description": "Schema for validating marimo Helm chart values",
  "type": "object",
  "$defs": {
    "imageVariant": {
      "type": "object",
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "digest": {
          "type": "string",
          "description": "Immutable image digest pin (decoupled from chart version). Empty to pin by tag only.",
          "pattern": "^(sha256:[a-f0-9]{64})?$"
        }
      },
      "required": ["repository"],
      "additionalProperties": false
    },
    "image": {
      "type": "object",
      "description": "Image is selected by injected GPU vendor (ADR-0003): amd -> ROCm-baked, else default (framework-free).",
      "properties": {
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
        "default": { "$ref": "#/$defs/imageVariant" },
        "amd": { "$ref": "#/$defs/imageVariant" }
      },
      "required": ["default"],
      "additionalProperties": false
    },
    "service": {
      "type": "object",
      "properties": {
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      },
      "required": ["port"],
      "additionalProperties": false
    },
    "gpu": {
      "type": "object",
      "properties": {
        "nvidia": {
          "type": "object",
          "properties": {
            "runtimeClassName": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "fallback": {
      "type": "object",
      "description": "Resources used only for a plain helm install; overridden by _exalsius injection.",
      "properties": {
        "cpu": { "type": "string", "minLength": 1 },
        "memory": { "type": "string", "minLength": 1 },
        "storage": { "type": "string", "minLength": 1 }
      },
      "required": ["cpu", "memory", "storage"],
      "additionalProperties": false
    },
    "exalsius": {
      "type": "object",
      "description": "Operator-injected resource/scheduling contract. Shape is owned by the operator, so it is intentionally not constrained here.",
      "additionalProperties": true
    }
  },
  "properties": {
    "image": { "$ref": "#/$defs/image" },
    "tokenPassword": {
      "type": "string",
      "description": "Password for marimo token authentication",
      "minLength": 1
    },
    "service": { "$ref": "#/$defs/service" },
    "gpu": { "$ref": "#/$defs/gpu" },
    "fallback": { "$ref": "#/$defs/fallback" },
    "_exalsius": { "$ref": "#/$defs/exalsius" }
  },
  "required": ["image", "tokenPassword", "service", "fallback"],
  "additionalProperties": false
}
